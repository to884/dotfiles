# Topgrade 設定ファイル
# chezmoi で管理されています
#
# Topgrade は様々なパッケージマネージャーやツールを一括更新するツールです
# 参考: https://github.com/topgrade-rs/topgrade

# ============================================================================
# 全般設定
# ============================================================================

# dry-run モードを有効にする（実際には更新しない）
# assume_yes = true

# タイムアウト設定（秒）
# set_title = false

# リモートホストも更新する
# run_in_tmux = false

# ============================================================================
# 更新対象の設定
# ============================================================================

[misc]
# システムの再起動が必要な場合に通知
# assume_yes = false

# ============================================================================
# Linux 固有の設定
# ============================================================================

[linux]
# yay、paru などの AUR ヘルパーをスキップする
# yay_arguments = "--nodevel"

# apt でのアップグレード時の設定
# apt_arguments = "--yes"

# ============================================================================
# Homebrew (Linuxbrew) の設定
# ============================================================================

[brew]
# Homebrew の自動クリーンアップを有効化
# greedy_cask = true

# ============================================================================
# Git リポジトリの設定
# ============================================================================

# [git]
# 特定のディレクトリ配下の Git リポジトリをすべて pull する
# repos = [
#     "~/projects/",
#     "~/workspace/",
# ]

# ============================================================================
# 無効化する更新処理
# ============================================================================

[disable]
# 無効化したいステップをリストアップ
# 例: system = true, brew_formula = true

# WSL環境ではシステムパッケージの自動更新を無効化する場合
{{- if eq .chezmoi.os "linux" }}
{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# system = true
{{- end }}
{{- end }}

# ============================================================================
# カスタムコマンド
# ============================================================================

# [commands]
# インストール後に実行するカスタムコマンド
# "Update Rust nightly" = "rustup update nightly"
# "Clean Docker" = "docker system prune -af"

# ============================================================================
# 通知設定
# ============================================================================

# [notifications]
# デスクトップ通知を有効化
# enabled = true
