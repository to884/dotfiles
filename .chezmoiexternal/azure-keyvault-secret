#!/bin/bash

# Azure Key Vaultからシークレットを取得するchezmoiヘルパースクリプト
# Usage: {{ output "azure-keyvault-secret" "vault-name" "secret-name" }}

VAULT_NAME="$1"
SECRET_NAME="$2"

if [ -z "$VAULT_NAME" ] || [ -z "$SECRET_NAME" ]; then
    echo "Usage: $0 <vault-name> <secret-name>" >&2
    exit 1
fi

# Azure CLIが利用可能かチェック
if ! command -v az &> /dev/null; then
    echo "Error: Azure CLI not found" >&2
    exit 1
fi

# ログイン状態をチェック
if ! az account show &>/dev/null; then
    echo "Error: Not logged in to Azure CLI" >&2
    exit 1
fi

# シークレットを取得
az keyvault secret show \
    --vault-name "$VAULT_NAME" \
    --name "$SECRET_NAME" \
    --query value \
    --output tsv 2>/dev/null || {
    echo "Error: Failed to retrieve secret '$SECRET_NAME' from vault '$VAULT_NAME'" >&2
    exit 1
}
