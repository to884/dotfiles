# ============================================================================
# .zshrc - Zsh シェル設定ファイル
# ============================================================================
#
# このファイルは chezmoi で管理されています
# 編集する場合は: chezmoi edit ~/.zshrc
#
# ============================================================================

# ============================================================================
# Linuxbrew
# ============================================================================

# Linuxbrew を PATH に追加
if [[ -d /home/linuxbrew/.linuxbrew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# ============================================================================
# starship プロンプト
# ============================================================================

# starship プロンプトを初期化
if command -v starship &> /dev/null; then
    eval "$(starship init zsh)"
fi

# ============================================================================
# History 設定
# ============================================================================

# コマンド履歴の保存数
HISTSIZE=10000
SAVEHIST=20000
HISTFILE=~/.zsh_history

# 重複したコマンドを履歴に保存しない
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS

# 履歴を共有
setopt SHARE_HISTORY

# 履歴にタイムスタンプを追加
setopt EXTENDED_HISTORY

# ============================================================================
# 補完設定
# ============================================================================

# 補完機能を有効化
autoload -Uz compinit
compinit

# 補完候補をメニュー表示
zstyle ':completion:*' menu select

# 補完候補を大文字小文字を区別せずに検索
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# ============================================================================
# エイリアス
# ============================================================================

# ls の色付けとエイリアス
if command -v eza &> /dev/null; then
    # ezaがインストールされている場合
    alias ls='eza --icons'
    alias ll='eza -alh --icons'
    alias la='eza -a --icons'
    alias lt='eza --tree --icons'
else
    # 標準のlsを使用
    alias ls='ls --color=auto'
    alias ll='ls -alh'
    alias la='ls -A'
fi

# cat の代わりに bat を使用
if command -v bat &> /dev/null; then
    alias cat='bat'
fi

# grep の色付け
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# 安全なファイル操作
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# ディレクトリ移動
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ============================================================================
# 環境変数
# ============================================================================

# エディタ設定
export EDITOR=vim
export VISUAL=vim

# ============================================================================
# その他の設定
# ============================================================================

# カラー対応のディレクトリリスト
export LS_COLORS='di=34:ln=35:so=32:pi=33:ex=31:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43'

# lessのオプション
export LESS='-R -F -X'

# PowerLine for tmux（pip3 --user でインストールされている場合）
if [[ -f ~/.local/lib/python*/site-packages/powerline/bindings/zsh/powerline.sh ]]; then
    powerline_script=$(find ~/.local/lib/python*/site-packages/powerline/bindings/zsh/powerline.sh 2>/dev/null | head -n1)
    if [[ -n "$powerline_script" ]]; then
        source "$powerline_script"
    fi
fi

# ============================================================================
# ユーザーカスタマイズ領域
# ============================================================================
# この下に個人的な設定を追加してください

