# ============================================================================
# .curlrc - curl グローバル設定ファイル
# ============================================================================
#
# このファイルは chezmoi で管理されています
# 編集する場合は: chezmoi edit ~/.curlrc
#
# ============================================================================

{{- $zscalerPem := joinPath .chezmoi.homeDir ".certs/ZscalerRootCA.pem" }}
{{- if stat $zscalerPem }}
# ============================================================================
# Zscaler SSL証明書設定
# ============================================================================
#
# Zscaler環境下でSSL証明書を検証するための設定
# 証明書ファイルは bootstrap.sh 実行時に自動的に変換・配置されます
#
# 証明書ファイルの配置場所:
#   - ソース: ~/.certs/ZscalerRootCA.cer (Windows形式)
#   - 変換後: ~/.certs/ZscalerRootCA.pem (PEM形式)
#
# ============================================================================

# Zscaler ルートCA証明書を指定
cacert = "{{ $zscalerPem }}"
{{- else }}
# ============================================================================
# Zscaler SSL証明書設定（未構成）
# ============================================================================
#
# Zscaler証明書がまだ配置されていません。
#
# セットアップ手順:
#   1. 証明書を配置: mkdir -p ~/.certs && cp ZscalerRootCA.cer ~/.certs/
#   2. bootstrap.sh を実行して証明書を変換
#   3. chezmoi apply で設定を再適用
#
# ============================================================================
{{- end }}
